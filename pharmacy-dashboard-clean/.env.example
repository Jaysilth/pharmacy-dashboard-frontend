# Where the Vite dev server proxies /api requests to. Only used by `npm run dev`.
VITE_API_PROXY_TARGET=http://localhost:8080

# Optional: only set this for a PRODUCTION build if the frontend is served from a
# different origin than the backend. Leave it unset if you're serving the built
# frontend from the same origin as the API (recommended — see README), in which
# case requests just go to relative "/api/..." paths and there's no CORS involved.
# VITE_API_BASE_URL=https://api.example.com

# Optional: dev server port (defaults to 5173)
# PORT=5173
